rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write, delete: if request.auth != null && request.auth.uid == userId;

      match /habits/{habitId} {
        // Allow read and delete for authenticated user
        allow read, delete: if request.auth != null && request.auth.uid == userId;
        
        // Allow write but restrict which fields can be written
        allow write: if request.auth != null && request.auth.uid == userId &&
          // Block direct writes to streak and lastCompletedDate (computed server-side)
          !request.resource.data.keys().hasAny(['streak', 'lastCompletedDate']);
      }
    }
  }
}
